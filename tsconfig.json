{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "outDir": "lib",
    "jsx": "react-native"
  },
  "include": ["src/"],
  "exclude": ["node_modules", "lib"]
}
